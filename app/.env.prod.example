# ── Variables Laravel (app/.env) ─────────────────────────────────────────────
# Copier en app/.env sur le serveur

APP_NAME=Taverne
APP_ENV=production
APP_KEY=                          # php artisan key:generate
APP_DEBUG=false
APP_URL=https://VOTRE_DOMAINE

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# Base de données (même valeurs que dans le .env racine)
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=taverne
DB_USERNAME=taverne
DB_PASSWORD=                      # même mot de passe que .env racine

SESSION_DRIVER=redis
SESSION_LIFETIME=120

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Reverb WebSocket (même clés que dans le .env racine)
REVERB_APP_ID=taverne
REVERB_APP_KEY=                   # même que .env racine
REVERB_APP_SECRET=                # même que .env racine
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http                # en interne Docker, pas besoin de TLS

# Ces vars sont utilisées par le build frontend (Vite), pas par PHP
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=VOTRE_DOMAINE
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

FRONTEND_URL=https://VOTRE_DOMAINE

# Mail — activer Resend en production
MAIL_MAILER=smtp
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_USERNAME=resend
MAIL_PASSWORD=re_VOTRE_CLÉ_RESEND
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=noreply@VOTRE_DOMAINE
MAIL_FROM_NAME="La Taverne"
