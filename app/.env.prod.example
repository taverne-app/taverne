# ── Variables Laravel (app/.env) ─────────────────────────────────────────────
# Copier en app/.env sur le serveur

APP_NAME=Taverne
APP_ENV=production
APP_KEY=                          # php artisan key:generate
APP_DEBUG=false
APP_URL=https://VOTRE_DOMAINE

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# Base de données
# O2switch : utiliser les identifiants MySQL/PostgreSQL du cPanel
DB_CONNECTION=mysql               # ou pgsql si PostgreSQL disponible
DB_HOST=localhost
DB_PORT=3306                      # 5432 pour PostgreSQL
DB_DATABASE=VOTRE_BDD
DB_USERNAME=VOTRE_USER_BDD
DB_PASSWORD=VOTRE_MDP_BDD

SESSION_DRIVER=file               # O2switch : "file" (pas de Redis requis)
SESSION_LIFETIME=120

BROADCAST_CONNECTION=pusher       # driver Pusher natif Laravel → Ably
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync             # emails envoyés synchrone, pas de worker requis

CACHE_STORE=file                  # O2switch : "file" (pas de Redis requis)

# Ably — API Pusher-compatible (gratuit sur ably.com)
# Récupérer les valeurs dans le dashboard Ably → API Keys
# Format clé Ably : "appId.keyId:secret"
ABLY_APP_ID=                      # partie avant le "."   (ex: xVLyHw)
ABLY_PUSHER_KEY=                  # appId.keyId           (ex: xVLyHw.ABCDEF)
ABLY_PUSHER_SECRET=               # partie après ":"      (ex: the_secret)

# Ces vars sont utilisées par le build Vite (frontend uniquement)
VITE_ABLY_KEY=                    # même valeur que ABLY_PUSHER_KEY

FRONTEND_URL=https://VOTRE_DOMAINE

# Mail
MAIL_MAILER=smtp
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_USERNAME=resend
MAIL_PASSWORD=re_VOTRE_CLÉ_RESEND
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=noreply@VOTRE_DOMAINE
MAIL_FROM_NAME="La Taverne"
