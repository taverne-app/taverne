# ── Variables lues par docker-compose (racine du projet) ─────────────────────
# Copier en .env à la racine du projet (déploiement Docker)
# Pour O2switch, ces variables vont directement dans app/.env

# Ably — API Pusher-compatible (gratuit sur ably.com)
# Clé Ably format "appId.keyId:secret" → décomposer comme suit :
ABLY_APP_ID=             # la partie avant le premier "."  (ex: xVLyHw)
ABLY_PUSHER_KEY=         # appId.keyId  sans le secret     (ex: xVLyHw.ABCDEF)
ABLY_PUSHER_SECRET=      # la partie après ":"             (ex: the_secret)

# Frontend : seule la clé publique (sans secret) va dans le build Vite
VITE_ABLY_KEY=           # même valeur que ABLY_PUSHER_KEY  (ex: xVLyHw.ABCDEF)

# Base de données PostgreSQL (Docker uniquement)
DB_DATABASE=taverne
DB_USERNAME=taverne
DB_PASSWORD=             # mot de passe fort

APP_ENV=production
