# ── Variables lues par docker-compose (racine du projet) ─────────────────────
# Copier en .env à la racine du projet

# Variables pour le build du frontend (Vite les intègre à la compilation)
VITE_REVERB_APP_KEY=          # même valeur que REVERB_APP_KEY ci-dessous
VITE_REVERB_HOST=VOTRE_DOMAINE
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

# Variables pour le conteneur reverb
REVERB_APP_ID=taverne
REVERB_APP_KEY=               # openssl rand -hex 16
REVERB_APP_SECRET=            # openssl rand -hex 32

# Variables pour le conteneur db (PostgreSQL)
DB_DATABASE=taverne
DB_USERNAME=taverne
DB_PASSWORD=                  # mot de passe fort

APP_ENV=production
